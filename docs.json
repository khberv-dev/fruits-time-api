    {
      "name": "Auth",
      "item": [
        {
          "name": "sign-up",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"phoneNumber\": \"+998901234567\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-up",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-up"]
            },
            "description": "Register a new user.\n\n**Body (CreateUserRequest)**\n- `firstName` (string, required)\n- `phoneNumber` (string, required)\n- `password` (string, required)"
          },
          "response": []
        },
        {
          "name": "sign-in",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+998901234567\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-in"]
            },
            "description": "Authenticate with phone number and password. Saves `accessToken` and `refreshToken` to collection variables on success.\n\n**Body (SignInRequest)**\n- `phoneNumber` (string, required)\n- `password` (string, required)"
          },
          "response": []
        },
        {
          "name": "refresh-token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{refreshToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Refresh access token using a valid refresh token (JWT Refresh Guard). Send the refresh token as Bearer in the Authorization header."
          },
          "response": []
        },
        {
          "name": "check-phone-number",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/check/{{phoneNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "check", "{{phoneNumber}}"]
            },
            "description": "Check whether a phone number is already registered.\n\n**Path Params**\n- `phoneNumber` (string, required)"
          },
          "response": []
        },
        {
          "name": "send-otp",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.otpId) pm.collectionVariables.set('otpId', json.otpId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+998901234567\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "send-otp"]
            },
            "description": "Send an OTP code to the given phone number. Returns an `otpId` saved to collection variables.\n\n**Body (SendOtpRequest)**\n- `phoneNumber` (string, required, exactly 12 chars)"
          },
          "response": []
        },
        {
          "name": "verify-otp",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-otp/{{otpId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-otp", "{{otpId}}"]
            },
            "description": "Verify an OTP code for a given OTP session.\n\n**Path Params**\n- `otpId` (string, required)\n\n**Body (VerifyOtpRequest)**\n- `code` (string)"
          },
          "response": []
        }
      ]
    },
