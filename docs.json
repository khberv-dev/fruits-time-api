{
  "info": {
    "_postman_id": "fruitstime-api-collection",
    "name": "fruitstime-api",
    "description": "NestJS REST API for Fruitstime. Global prefix: /api. Authentication uses JWT Bearer tokens (access + refresh). Locale query param (uz|ru|en) is required on most endpoints.",
